# Required for POST /api/parse (coach mode prescription parsing).
# Get a key at https://aistudio.google.com/apikey
GEMINI_API_KEY=your-gemini-api-key
# Optional: override the default model (gemini-2.5-flash)
# GEMINI_MODEL=gemini-2.5-flash

# Optional: enables in-app YouTube video search/embed (GET /api/youtube).
# A Google Cloud API key with "YouTube Data API v3" enabled.
# https://console.cloud.google.com/apis/library/youtube.googleapis.com
# Without it, video blocks fall back to a tap-to-search YouTube link.
YOUTUBE_API_KEY=your-youtube-data-api-key
